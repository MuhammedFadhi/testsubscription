# N-Genius Payment Gateway (Sandbox - KSA)
# Copy this file to ".env" and fill in the values you receive from N-Genius.

# Base URL for the sandbox API gateway
NGENIUS_BASE_URL=https://api-gateway.sandbox.ksa.ngenius-payments.com

# API Key issued by N-Genius (used as Basic auth to get an access token)
NGENIUS_API_KEY=

# Outlet reference / outlet ID provided by N-Genius (used as the token "scope"
# and in the orders endpoint URL)
NGENIUS_OUTLET_REF=

# Local server port
PORT=3000
